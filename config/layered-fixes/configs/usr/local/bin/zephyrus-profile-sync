#!/bin/bash
# Zephyrus GU605MY OEM Profile Sync
# Replicates Armoury Crate behavior on Linux
# Called automatically when ASUS profile changes
#
# OEM Values from decoded DSDT + UltrabookReview validation:
#   Silent:      CPU PL1=55W PL2=60W,  GPU=55W,  Boost=OFF, Governor=powersave
#   Balanced:    CPU PL1=70W PL2=95W,  GPU=90W,  Boost=ON,  Governor=performance
#   Performance: CPU PL1=95W PL2=115W, GPU=105W, Boost=ON,  Governor=performance

LOGFILE="/var/log/zephyrus-profile.log"
RAPL_PATH="/sys/class/powercap/intel-rapl/intel-rapl:0"
NO_TURBO="/sys/devices/system/cpu/intel_pstate/no_turbo"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" | tee -a "$LOGFILE" >/dev/null
}

# Set Intel RAPL power limits (microWatts)
set_rapl() {
    local pl1_w=$1
    local pl2_w=$2
    local rapl="$RAPL_PATH"
    test -d "$rapl" || return

    local pl1_uw=$((pl1_w * 1000000))
    local pl2_uw=$((pl2_w * 1000000))

    echo "$pl1_uw" > "$rapl/constraint_0_power_limit_uw" 2>/dev/null || true
    echo "$pl2_uw" > "$rapl/constraint_1_power_limit_uw" 2>/dev/null || true
    echo "28000000" > "$rapl/constraint_0_time_window_us" 2>/dev/null || true

    log "RAPL set: PL1=${pl1_w}W PL2=${pl2_w}W"
}

# Set CPU governor
set_governor() {
    local gov=$1
    for cpu in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_governor; do
        echo "$gov" > "$cpu" 2>/dev/null || true
    done
    log "Governor: $gov"
}

# Set CPU Energy Performance Preference (EPP)
set_epp() {
    local epp=$1
    for cpu in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/energy_performance_preference; do
        [ -w "$cpu" ] && echo "$epp" > "$cpu" 2>/dev/null || true
    done
    log "EPP: $epp"
}

# Set CPU boost (turbo) — use kernel interface directly
set_boost() {
    local enable=$1
    if [ -w "$NO_TURBO" ]; then
        if [ "$enable" = "true" ]; then
            echo 0 > "$NO_TURBO" 2>/dev/null || true
            log "Boost: ON"
        else
            echo 1 > "$NO_TURBO" 2>/dev/null || true
            log "Boost: OFF"
        fi
    else
        # Fallback: try asusctl (newer versions)
        asusctl profile --boost-set "$enable" >/dev/null 2>&1 || true
        log "Boost: $enable (via asusctl fallback)"
    fi
}

# Set NVIDIA GPU power limit
set_gpu_pl() {
    local pl=$1
    command -v nvidia-smi &>/dev/null || return
    nvidia-smi -pl "$pl" >/dev/null 2>&1 || true
    log "GPU PL: ${pl}W"
}

# Manage irqbalance
set_irqbalance() {
    local enable=$1
    if [ "$enable" = "true" ]; then
        systemctl start irqbalance 2>/dev/null || true
        systemctl enable irqbalance 2>/dev/null || true
        log "irqbalance: ON"
    else
        systemctl stop irqbalance 2>/dev/null || true
        systemctl disable irqbalance 2>/dev/null || true
        log "irqbalance: OFF"
    fi
}

# Manage thermald
set_thermald() {
    local enable=$1
    if [ "$enable" = "true" ]; then
        systemctl start thermald 2>/dev/null || true
        systemctl enable thermald 2>/dev/null || true
        log "thermald: ON"
    else
        systemctl stop thermald 2>/dev/null || true
        systemctl disable thermald 2>/dev/null || true
        log "thermald: OFF"
    fi
}

# Apply complete OEM profile
apply_profile() {
    local profile=$1
    local asus_profile=""
    local gpu_pl=""
    local pl1=""
    local pl2=""
    local governor=""
    local boost=""
    local epp=""
    local irqbal=""
    local therm=""

    case "$profile" in
        Quiet|Silent|quiet|silent)
            asus_profile="Quiet"
            gpu_pl=55
            pl1=55
            pl2=60
            governor="powersave"
            boost="false"
            epp="power"
            irqbal="false"
            therm="true"
            ;;
        Balanced|balanced)
            asus_profile="Balanced"
            gpu_pl=90
            pl1=70
            pl2=95
            governor="performance"
            boost="true"
            epp="balance_performance"
            irqbal="true"
            therm="true"
            ;;
        Performance|Turbo|performance|turbo)
            asus_profile="Performance"
            gpu_pl=105
            pl1=95
            pl2=115
            governor="performance"
            boost="true"
            epp="performance"
            irqbal="true"
            therm="false"
            ;;
        *)
            log "Unknown profile: $profile, defaulting to Performance"
            asus_profile="Performance"
            gpu_pl=105
            pl1=95
            pl2=115
            governor="performance"
            boost="true"
            epp="performance"
            irqbal="true"
            therm="false"
            ;;
    esac

    log "=== Applying OEM profile: $asus_profile ==="

    # 1. ASUS platform profile (tells EC which mode — EC handles fans automatically)
    asusctl profile -P "$asus_profile" >/dev/null 2>&1 || true

    # 2. CPU boost (turbo) — direct kernel control
    set_boost "$boost"

    # 3. Intel RAPL CPU power limits
    set_rapl "$pl1" "$pl2"

    # 4. GPU power limit
    set_gpu_pl "$gpu_pl"

    # 5. CPU governor
    set_governor "$governor"

    # 6. Energy Performance Preference
    set_epp "$epp"

    # 7. IRQ balance
    set_irqbalance "$irqbal"

    # 8. Thermal daemon (disable for gaming to prevent DPTF throttling)
    set_thermald "$therm"

    # 9. Persist for sleep/resume
    echo "$gpu_pl" > /etc/zephyrus-crimson/gpu-power-limit 2>/dev/null || true

    log "=== Profile $asus_profile applied ==="
}

# Detect current ASUS profile
detect_profile() {
    asusctl profile get 2>/dev/null | grep -oP 'Active profile: \K\w+' || echo "Performance"
}

# Main
case "${1:-sync}" in
    sync|s)
        CURRENT=$(detect_profile)
        apply_profile "$CURRENT"
        ;;
    quiet|silent)
        apply_profile "Quiet"
        ;;
    balanced)
        apply_profile "Balanced"
        ;;
    performance|turbo)
        apply_profile "Performance"
        ;;
    status|st)
        CURRENT=$(detect_profile)
        echo "Active ASUS profile: $CURRENT"
        if command -v nvidia-smi &>/dev/null; then
            echo "GPU Power Limit: $(nvidia-smi --query-gpu=power.limit --format=csv,noheader 2>/dev/null | tr -d ' ')"
        fi
        if [ -r "$NO_TURBO" ]; then
            turbo=$(cat "$NO_TURBO" 2>/dev/null)
            [ "$turbo" = "0" ] && echo "CPU Boost: ON" || echo "CPU Boost: OFF"
        fi
        if [ -d "$RAPL_PATH" ]; then
            echo "CPU PL1: $(( $(cat "$RAPL_PATH/constraint_0_power_limit_uw" 2>/dev/null || echo 0) / 1000000 ))W"
            echo "CPU PL2: $(( $(cat "$RAPL_PATH/constraint_1_power_limit_uw" 2>/dev/null || echo 0) / 1000000 ))W"
        fi
        if [ -r /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference ]; then
            echo "EPP: $(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2>/dev/null)"
        fi
        systemctl is-active irqbalance >/dev/null 2>&1 && echo "irqbalance: ON" || echo "irqbalance: OFF"
        systemctl is-active thermald >/dev/null 2>&1 && echo "thermald: ON" || echo "thermald: OFF"
        ;;
    *)
        echo "Usage: $0 [sync|quiet|balanced|performance|status]"
        exit 1
        ;;
esac
